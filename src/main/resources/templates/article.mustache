{{> header}}

<main>
  <section class="article">
    <div class="article-header">
      <h1 class="article-title">{{article.title}}</h1>
      <p class="article-meta">
        By <strong><a href="/user/{{article.author.login}}">{{article.author.firstname}}</a></strong>, on <strong>{{article.addedAt}}</strong> &middot; {{article.views}} views &middot; <span id="likeCount">{{article.likes}}</span> likes
        <button id="likeButton" style="margin-left: 0.5rem; cursor: pointer; padding: 0.2rem 0.5rem; background: var(--bg-1); border: 1px solid var(--border); border-radius: var(--radius-sm);">👍 Like</button>
      </p>
      <div class="article-taxonomies">
        {{#article.category}}
          <a href="/category/{{slug}}" class="badge badge-category">{{name}}</a>
        {{/article.category}}
        {{#article.tags}}
          <a href="/tag/{{slug}}" class="badge badge-tag">{{name}}</a>
        {{/article.tags}}
      </div>
    </div>

    <div class="article-description">
      <p class="headline">{{article.headline}}</p>
      <div class="content">{{{article.content}}}</div>
    </div>

    {{#hasRelatedArticles}}
    <section class="related-articles">
      <h2 class="section-title">Related Articles</h2>
      <div class="articles-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: var(--space-6); margin-top: var(--space-4);">
        {{#relatedArticles}}
          <article class="article-card" style="display: flex; flex-direction: column; background: var(--bg-1); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-4); transition: transform 0.2s, box-shadow 0.2s;">
            <h3 style="margin: 0 0 var(--space-2); font-size: 1.1rem;"><a href="/article/{{slug}}" style="text-decoration: none; color: var(--text-heading);">{{title}}</a></h3>
            <p style="margin: 0; font-size: 0.9rem; color: var(--text-body); flex-grow: 1;">{{headline}}</p>
            <div class="article-card-meta" style="margin-top: var(--space-3); font-size: 0.8rem; color: var(--text-muted);">
              {{author.firstname}} &middot; {{addedAt}}
            </div>
          </article>
        {{/relatedArticles}}
      </div>
    </section>
    {{/hasRelatedArticles}}

    <section class="comments-section">
      <h2 class="comments-title">Comments</h2>
      {{#comments}}
        <div class="comment">
          <div class="comment-header">
            By <strong>{{author.firstname}}</strong>, on <strong>{{addedAt}}</strong>
          </div>
          <p class="comment-content">{{content}}</p>
        </div>
      {{/comments}}
      {{^comments}}
        <p>No comments yet. Be the first to comment!</p>
      {{/comments}}

      <script>
        document.getElementById('likeButton')?.addEventListener('click', async () => {
          try {
            const response = await fetch('/api/article/{{article.slug}}/like', {
              method: 'POST'
            });
            if (response.ok) {
              const data = await response.json();
              document.getElementById('likeCount').innerText = data.likes;
            }
          } catch (error) {
            console.error('Error liking article:', error);
          }
        });
      </script>

      {{#user}}
      <div class="comment-form">
        <h3>Add a Comment</h3>
        <form id="addCommentForm">
          <div class="form-group">
            <label for="commentContent">Comment</label>
            <textarea id="commentContent" name="content" rows="4" required placeholder="Write your comment here..."></textarea>
          </div>
          <input type="hidden" id="articleSlug" name="articleSlug" value="{{article.slug}}">
          <button type="submit">Submit Comment</button>
        </form>
      </div>

      <script>
        document.getElementById('addCommentForm').addEventListener('submit', async (e) => {
          e.preventDefault();
          const content = document.getElementById('commentContent').value;
          const articleSlug = document.getElementById('articleSlug').value;

          try {
            const response = await fetch('/api/comment/', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ articleSlug, content })
            });

            if (response.ok) {
              location.reload();
            } else {
              alert('Failed to submit comment. Are you still logged in?');
            }
          } catch (error) {
            console.error('Error:', error);
            alert('An error occurred');
          }
        });
      </script>
      {{/user}}
      {{^user}}
      <p style="margin-top: var(--space-6); text-align: center;">
        Please <a href="/login">login</a> to add a comment.
      </p>
      {{/user}}
    </section>
  </section>
</main>

{{> footer}}
