{{> header}}

<!-- Dependencies for EasyMDE -->
<link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">
<script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>
<!-- Font Awesome for EasyMDE icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<main>
<section class="new-article">
  <h1>Create New Article</h1>
  <div class="article-form">
    <form id="articleForm">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4);">
        <p>
          <label for="title">Title</label>
          <input type="text" id="title" name="title" required placeholder="Enter article title">
        </p>
        <p>
          <label for="headline">Headline</label>
          <input type="text" id="headline" name="headline" required placeholder="A short catchy headline">
        </p>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4);">
        <p>
          <label for="category">Category</label>
          <input type="text" id="category" name="category" placeholder="e.g. Frameworks">
        </p>
        <p>
          <label for="tags">Tags (comma-separated)</label>
          <input type="text" id="tags" name="tags" placeholder="e.g. Spring, Kotlin, JPA">
        </p>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4);">
        <p>
          <label for="status">Status</label>
          <select id="status" name="status" style="width: 100%; padding: 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--grey-70); background: var(--bg-surface); color: var(--text-main); font-family: inherit; cursor: pointer;">
            <option value="DRAFT">Draft</option>
            <option value="PUBLISHED">Published</option>
          </select>
        </p>
        <p>
          <label for="scheduledAt">Schedule Publication (Optional)</label>
          <input type="datetime-local" id="scheduledAt" name="scheduledAt" style="width: 100%; padding: 0.65rem; border-radius: var(--radius-md); border: 1px solid var(--grey-70); background: var(--bg-surface); color: var(--text-main); font-family: inherit;">
        </p>
      </div>

      <p>
        <label for="content">Content (Markdown)</label>
        <textarea id="content" name="content" placeholder="Write your article in Markdown..."></textarea>
      </p>
      <button type="submit" class="btn-primary">Save Article</button>
    </form>
  </div>
  <div id="articleMessage" class="message"></div>
</section>
</main>

<script>
  const easyMDE = new EasyMDE({
    element: document.getElementById('content'),
    spellChecker: false,
    autosave: {
        enabled: true,
        uniqueId: "spring-demo-new-article",
        delay: 1000,
    },
    promptURLs: true,
    placeholder: "Write your article in Markdown...",
    renderingConfig: {
        singleLineBreaks: false,
        codeSyntaxHighlighting: true,
    }
  });

  document.getElementById('articleForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const tagsValue = document.getElementById('tags').value;
    const tags = tagsValue ? tagsValue.split(',').map(t => t.trim()).filter(t => t) : [];
    
    let scheduledAt = document.getElementById('scheduledAt').value;
    if (scheduledAt) {
      scheduledAt = new Date(scheduledAt).toISOString().split('.')[0];
    }

    const data = {
      title: document.getElementById('title').value,
      headline: document.getElementById('headline').value,
      content: easyMDE.value(),
      category: document.getElementById('category').value || null,
      tags: tags,
      status: document.getElementById('status').value,
      scheduledAt: scheduledAt || null
    };

    fetch('/api/article/', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(data)
    })
    .then(response => {
      if (response.ok) {
        return response.json().then(article => {
          window.location.href = '/article/' + article.slug;
        });
      } else {
        return response.json().then(error => {
          document.getElementById('articleMessage').innerHTML = '<p class="error">Error: ' + (error.message || 'Failed to create article') + '</p>';
        });
      }
    })
    .catch(error => {
      document.getElementById('articleMessage').innerHTML = '<p class="error">An unexpected error occurred.</p>';
    });
  });
</script>

{{> footer}}
